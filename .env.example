# Copy to .env. Never commit .env.
APP_NAME=Voice Companion
GREETING=Hello

# Your OpenAI-compatible chat-completions endpoint.
AGENT_API_URL=http://127.0.0.1:8080/v1/chat/completions
AGENT_API_KEY=replace-if-your-agent-requires-a-key
AGENT_MODEL=your-agent-model
AGENT_SYSTEM_PROMPT=You are a helpful, concise voice companion.

# Required local or private HTTP speech services.
# STT accepts raw browser audio and returns JSON: {"text":"..."}.
STT_API_URL=http://127.0.0.1:9000/v1/transcribe
# TTS accepts {"text","voice","speed"} and returns an audio response.
TTS_API_URL=http://127.0.0.1:9001/v1/synthesize
VOICE_NAME=default
VOICE_SPEED=1.0

# Leave host loopback-only unless you have a trusted reverse proxy.
VOICE_COMPANION_HOST=127.0.0.1
VOICE_COMPANION_PORT=8787
# Required if you deliberately bind beyond localhost. Send as Bearer token.
VOICE_COMPANION_TOKEN=
